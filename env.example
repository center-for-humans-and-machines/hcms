MODEL_API_KEY=
MODEL_ENDPOINT=
MODEL_API_VERSION=2024-08-01-preview
BATCH_MODEL_NAME=gpt-4o-global-batch
CHAT_COMPLETIONS_MODEL_NAME=gpt-4o-2024-08-06

LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=pk-
LANGFUSE_SECRET_KEY=sk-

LLAMA_GUARD_API_KEY=
LLAMA_GUARD_ENDPOINT=

OPENAI_MODERATION_API_KEY=

MONGODB_URI=mongodb://localhost:27017/?directConnection=true
MONGODB_DATABASE=
MONGODB_COLLECTION=Conversations
# Change stream server-side await timeout in milliseconds.
MONGODB_CHANGE_STREAM_MAX_AWAIT_MS=1000
# Startup backfill query batch size.
MONGODB_BACKFILL_BATCH_SIZE=200
# Startup backfill per-provider retry budget.
MONGODB_BACKFILL_MAX_RETRIES=10
# Sleep between no-progress startup backfill retries in seconds.
MONGODB_BACKFILL_RETRY_SLEEP_SECONDS=2
# Change stream reconnect exponential backoff base delay in seconds.
MONGODB_RECONNECT_BACKOFF_BASE_SECONDS=1
# Change stream reconnect exponential backoff max delay in seconds.
MONGODB_RECONNECT_BACKOFF_MAX_SECONDS=30
# Random jitter added to reconnect delays in seconds.
MONGODB_RECONNECT_BACKOFF_JITTER_SECONDS=0.25

# Runtime log level (DEBUG, INFO, WARNING, ERROR).
HPMS_LOG_LEVEL=INFO
